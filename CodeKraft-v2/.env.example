# ── Hugging Face ─────────────────────────────────────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_api_token_here

# Model for error-type classification.
# Option A (recommended): your fine-tuned CodeBERT  →  karan-patel11/codekraft-codebert
# Option B (fallback):    base CodeBERT             →  microsoft/codebert-base
HF_MODEL=microsoft/codebert-base

# ── OpenAI (OPTIONAL — Layer 4 only) ────────────────────────────────────────
# Only needed for the async LLM enrichment layer.
# The system works fully without this — Layers 1-3 provide instant hints.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,*
